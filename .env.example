# Docker Compose environment template (copy to `.env` and fill values)

MONGO_URI="mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority"
MONGO_DNS_FALLBACK_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET="<change-me-to-a-strong-random-secret>"
PORT=5000
FRONTEND_URL="https://malwa-hardware-2.onrender.com/api/faqs"
MAX_UPLOAD_SIZE_MB=5
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="malwa"
ADMIN_SEED_USERNAME="<admin-username>"
ADMIN_SEED_PASSWORD="<admin-password>"
